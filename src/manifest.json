{
  "manifest_version": 3,
  "name": "Obsidian Gmail Clipper",
  "version": "0.1.0",
  "description": "Clip Gmail emails to Obsidian in rich Markdown format with full formatting, attachments, and thread structure.",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "scripting",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Clip current email to Obsidian"
    }
  }
}
